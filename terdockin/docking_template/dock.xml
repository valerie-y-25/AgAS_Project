<?xml-model href="/home/marksd/rosscripts/rosettascripts.xsd"?>

<ROSETTASCRIPTS>
      <SCOREFXNS>
               <ScoreFunction name="myscore" weights="ref2015_cst.wts"/> 
      </SCOREFXNS>
      <SCORINGGRIDS ligand_chain="A" width="20.0">
		<ClassicGrid grid_name="dock_grid" weight="1.0"/>
      </SCORINGGRIDS>
      <TASKOPERATIONS>
               <DetectProteinLigandInterface name="design_detect" resfile="dock.resfile" design="1" cut1="6.0" cut2="8.0" cut3="10.0" cut4="12.0"/>
               <DetectProteinLigandInterface name="interface_detect" design="0" cut1="8.0" cut2="10.0" cut3="11.0" cut4="12.0"/>
               <LimitAromaChi2 name="limchi2"/>
               <SetCatalyticResPackBehavior name="catres" fix_catalytic_aa="0"/>
               <SetCatalyticResPackBehavior name="fixcat" fix_catalytic_aa="1"/>
               <ProteinLigandInterfaceUpweighter name="up" interface_weight="1.5"/>
               <ReadResfile name="resdes" filename="dock.resfile"/>
	            <RestrictToRepacking name="repack" />
      </TASKOPERATIONS>
      <FILTERS>
               <EnzScore name="allcst" score_type="cstE" scorefxn="myscore" whole_pose="1" energy_cutoff="2000"/> here not set to infinite 
               <DSasa name="lig_sasa" lower_threshold="0.0" upper_threshold="1.0" />
      </FILTERS>
      <MOVERS>
               <AddOrRemoveMatchCsts name="cstadd" cst_instruction="add_new"/> 
               <FavorNativeResidue name="fnr" bonus="1.5"/>
               <FastRelax name="fastdes" scorefxn="myscore" task_operations="interface_detect"/>
               <EnzRepackMinimize name="desmin_nobb" design="1" repack_only="0" scorefxn_minimize="myscore" scorefxn_repack="soft_rep" minimize_rb="1" rb_min_jumps="1,2,3" minimize_sc="1" minimize_bb="0" cycles="1" minimize_lig="0" min_in_stages="0" backrub="0" task_operations="design_detect,limchi2,catres"/>

               <StartFrom name="start_from" chain="C">
                  <Coordinates x="-19.258" y="-4.74" z="18.597"/>
               </StartFrom>
             
               <StartFrom name="start_from2" chain="B">
                  <Coordinates x="-21.158" y="-3.833" z="21.065"/>
               </StartFrom>

	       <Transform name="predock" chain="C" box_size="20" move_distance="10" angle="360" cycles="1000" repeats="3" temperature="5"/>
               <Transform name="predock2" chain="B" box_size="2" move_distance="0.5" angle="360" cycles="1000" repeats="3" temperature="5"/>		       <EnzRepackMinimize name="repack_wbb" design="0" repack_only="1" scorefxn_minimize="myscore" scorefxn_repack="myscore" minimize_rb="1" rb_min_jumps="1,2,3"  minimize_sc="1" minimize_bb="1" cycles="1" minimize_lig="1" min_in_stages="0" backrub="0" task_operations="interface_detect,limchi2,catres"/>
               <EnzRepackMinimize name="cstopt" cst_opt="1" minimize_rb="1" minimize_sc="1" minimize_bb="1" cycles="3" min_in_stages="0" minimize_lig="1" rb_min_jumps="1,2,3" task_operations="interface_detect,limchi2,catres"/>


               <ParsedProtocol name="dock_pak">
                  <Add mover="predock"/>
                  <Add mover="predock2"/>
                  <Add mover="cstopt"/>
                  <Add mover="desmin_nobb"/>
                  <Add mover="repack_wbb"/>
               </ParsedProtocol>

               <GenericMonteCarlo name="interative_dp" mover_name="dock_pak" scorefxn_name="myscore" trials="3" sample_type="low" temperature="0.6" drift="1"/>

               <EnzRepackMinimize name="repack_wbb_wppi" design="0" repack_only="1" scorefxn_minimize="myscore" scorefxn_repack="myscore" minimize_rb="1" rb_min_jumps="1,2,3"  minimize_sc="1" minimize_bb="1" cycles="2" minimize_lig="1" min_in_stages="0" backrub="0" task_operations="interface_detect,limchi2,catres"/>
      </MOVERS>

      <PROTOCOLS>
               <Add mover_name="cstadd"/>
               <Add mover_name="fnr"/>
               <Add mover="start_from"/>
	            <Add mover="start_from2"/>
               <Add mover="interative_dp"/>
               <Add mover="repack_wbb_wppi"/>
	            <Add filter_name="allcst"/>
               <Add filter_name="lig_sasa"/>
      </PROTOCOLS>

</ROSETTASCRIPTS>
